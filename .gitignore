# pixi environments
.pixi/*
!.pixi/config.toml

# LaTeX build intermediates; keep generated submission sources/artifacts visible.
paper/build/*
!paper/build/
!paper/build/*.md
!paper/build/*.tex
!paper/build/*.pdf

# Python caches
__pycache__/
*.pyc

# Quarto website output
paper/site/_site/
paper/site/.quarto/
